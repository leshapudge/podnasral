DATABASE_URL="postgresql://YOUR_USER@localhost:5432/podnasral?schema=public"
AUTH_SECRET="generate-with-openssl-rand-base64-32-min-32-chars"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Twitch OAuth — https://dev.twitch.tv/console/apps
AUTH_TWITCH_ID=""
AUTH_TWITCH_SECRET=""

# Comma-separated twitch logins → STREAMER role on login
STREAMER_TWITCH_LOGINS="kazanfarik,blindzonexgod,kwwwinn,kyotowave,xu3t"

# Twitch logins that can run auctions before event status becomes ACTIVE
PRESTART_AUCTION_TWITCH_LOGINS="kazanfarik"

# Comma-separated twitch IDs or logins → ADMIN role
ADMIN_TWITCH_IDS="566104351"
ADMIN_TWITCH_LOGINS="kazanfarik"

# RAWG — https://rawg.io/apidocs
RAWG_API_KEY=""

# Twitch Helix for live status cron (can reuse Twitch app credentials)
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""

CRON_SECRET="dev-cron-secret"

# Public app URL (used to build absolute webhook URL in streamer panel)
APP_BASE_URL="http://localhost:3000"

# Optional legacy secret for global endpoint /api/integrations/donationalerts
DONATIONALERTS_WEBHOOK_SECRET="dev-da-webhook-secret"
